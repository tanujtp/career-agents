# career-ops LangChain agent — environment variables
# Copy to .env in the career-ops root and fill in your values.

# Required
OPENAI_API_KEY=sk-...

# Optional — default is gpt-4o
# Options: gpt-4o | gpt-4o-mini | gpt-4-turbo
# gpt-4o-mini is ~10x cheaper, slightly lower eval quality
CAREER_OPS_MODEL=gpt-4o
