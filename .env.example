# Career Agents — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Required Integrations ─────────────────────────────────────────

# OpenAI API Key (Required for the pipeline to function)
# Get yours here: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Optional: Override Default Model ─────────────────────────────
# Default is usually gpt-4o. You can specify a different model if desired.
CAREER_OPS_MODEL=gpt-4o
